{
  "name": "eslint-config-lintastic",
  "version": "1.2.20",
  "description": "Eslint Remoto con las reglas unificadas de Asincode",
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "node --run lint -- --fix",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "test": "vitest --coverage --reporter=default",
    "test:integration": "node run --test ./test/integration/*",
    "test:watch": "node --run test -- --watch",
    "test:coverage": "npx c8 npm test"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asincode-sas/eslint-config-lintastic.git"
  },
  "keywords": [],
  "author": "Habid Manzur <hmanzur>",
  "license": "MIT",
  "dependencies": {
    "@html-eslint/parser": "^0.61.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^3.0.4",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.61.0",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-dom": "^5.8.9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^5.8.9",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "bugs": {
    "url": "https://github.com/asincode-sas/eslint-config-lintastic/issues"
  },
  "homepage": "https://github.com/asincode-sas/eslint-config-lintastic#readme",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix",
      "vitest --changed"
    ]
  }
}
